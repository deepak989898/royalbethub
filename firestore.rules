rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /sites/{siteId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /analytics_events/{id} {
      allow create: if request.resource.data.createdAt is timestamp
        && request.resource.data.type in ['visit', 'click']
        && (
          (request.resource.data.type == 'visit'
            && request.resource.data.keys().hasOnly(['type', 'createdAt', 'path', 'sessionId']))
          || (request.resource.data.type == 'click'
            && request.resource.data.keys().hasOnly(['type', 'createdAt', 'siteSlug', 'path', 'sessionId']))
        );
      allow read: if isAdmin();
    }

    match /bonus_leads/{id} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'siteSlug', 'siteName', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.siteSlug is string
        && request.resource.data.siteName is string
        && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
